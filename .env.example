# Eldorado Seller Bot configuration

# Eldorado API
ELDORADO_BASE_URL=https://www.eldorado.gg
ELDORADO_EMAIL=senin_mailin@ornek.com             # Headless Chrome login için
ELDORADO_PASSWORD=buraya_sifreni_yaz              # Headless Chrome login için
ELDORADO_COOKIES=                                 # Opsiyonel: manuel cookie, boş bırakılırsa otomatik login olur
ELDORADO_XSRF_TOKEN=                             # Opsiyonel: manuel XSRF token
VALORANT_GAME_ID=32                              # Valorant game ID

# Polling intervals
POLL_INTERVAL_OPEN_ORDERS=10s
POLL_INTERVAL_ORDER_STATUS=10s
POLL_INTERVAL_BUYER_REPLY=10s
POLL_INTERVAL_PRICING_RELOAD=15s

# Telegram (yeni oluşturacağın bot için)
TELEGRAM_BOT_TOKEN=BURAYA_YENI_TELEGRAM_TOKEN
TELEGRAM_CHAT_ID=0                               # getUpdates çıktısından chat.id

# Offer logic
MIN_OFFER_PRICE=5                                # Minimum teklif fiyatı (RR indirimi sonrası taban, 0=kapalı)
MAX_OFFER_PRICE=0
PRICING_PATH=pricing.json                        # Fiyatlandırma dosyası (her 60s yeniden okunur)
OFFER_MESSAGE=Merhaba, hızlı ve güvenli boost yapabilirim.
DELIVERY_TIME=Hour3

# Auto message to buyer
BUYER_AUTO_MESSAGE=                             # Boş: sabit şablon kullanılır
BUYER_AUTO_IMAGE=Radifix.jpeg                   # Offer sonrası gönderilecek görsel (önce görsel, sonra text), boş=API mesaj dener

# TalkJS API (mesaj API ile gönderilsin)
TALKJS_NYM_ID=                                  # Eldorado iframe'de user/xxx_n
TALKJS_TOKEN=                                   # Opsiyonel, boşsa Eldorado authorize denenir

# Chat server (persistent browser, paralel mesaj, hızlı gönderim)
CHAT_SERVER_URL=http://127.0.0.1:38521          # Boş=her mesajda yeni browser
CHAT_SERVER_PORT=38521                          # Server port
CHAT_SERVER_MAX_CONCURRENT=5                    # Aynı anda max kaç mesaj
CHAT_SERVER_TAB_MAX_AGE_SEC=300                 # Eski sekmeler kapanır (5 dk)
CHAT_SERVER_CLEANUP_INTERVAL_SEC=60             # Temizlik aralığı

# Görsel optimizasyonu (Pillow gerekli: pip install Pillow)
CHAT_IMAGE_MAX_KB=200                           # Max görsel boyutu, aşılırsa sıkıştırılır
