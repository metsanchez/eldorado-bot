# Eldorado Seller Bot configuration

# Eldorado API
ELDORADO_BASE_URL=https://www.eldorado.gg
ELDORADO_EMAIL=senin_mailin@ornek.com             # Headless Chrome login için
ELDORADO_PASSWORD=buraya_sifreni_yaz              # Headless Chrome login için
ELDORADO_COOKIES=                                 # Opsiyonel: manuel cookie, boş bırakılırsa otomatik login olur
ELDORADO_XSRF_TOKEN=                             # Opsiyonel: manuel XSRF token
VALORANT_GAME_ID=32                              # Valorant game ID

# Polling intervals
POLL_INTERVAL_OPEN_ORDERS=30s
POLL_INTERVAL_ORDER_STATUS=30s

# Telegram (yeni oluşturacağın bot için)
TELEGRAM_BOT_TOKEN=BURAYA_YENI_TELEGRAM_TOKEN
TELEGRAM_CHAT_ID=0                               # getUpdates çıktısından chat.id

# Offer logic
MIN_OFFER_PRICE=5                                # Minimum teklif fiyatı (RR indirimi sonrası taban, 0=kapalı)
MAX_OFFER_PRICE=0
OFFER_MESSAGE=Merhaba, hızlı ve güvenli boost yapabilirim.

